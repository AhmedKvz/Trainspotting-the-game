<!DOCTYPE html>
<html><head><meta charset="utf-8">
<style>*{margin:0;padding:0;box-sizing:border-box}body{background:#000;display:flex;align-items:center;justify-content:center;height:100vh}canvas{display:block}</style>
</head><body><canvas id="c"></canvas><script>
const CV=document.getElementById('c');
const W=CV.width=800,H=CV.height=500;
const cx=CV.getContext('2d');

const VY=132,NY=438,NS=0.83;
function prj(wx,wz){const t=1-Math.max(0,Math.min(1,wz));return{x:W/2+wx*t*NS,y:VY+t*(NY-VY),s:t};}
const W_WX=-312,W_HT=148,W_LN=0.21,W_GAP=0.05;

const DRUGS=[
  {id:'heroin', name:'HEROIN', icon:'💉',col:'#c0392b',glo:'#ff5555',dur:9000, msg:'...sve usporava...',   hard:true},
  {id:'acid',   name:'ACID',  icon:'🔮',col:'#8e44ad',glo:'#dd44ff',dur:10000,msg:'REALNOST SE TOPI!!!', hard:false},
  {id:'cocaine',name:'KOKAIN',icon:'❄️',col:'#2980b9',glo:'#88bbff',dur:7000, msg:'DUPLI SKOK! ULETI!',  hard:false},
  {id:'speed',  name:'SPEED', icon:'⚡',col:'#d35400',glo:'#ff9900',dur:8000, msg:'⚡⚡ PUNI GAS ⚡⚡',   hard:false},
  {id:'weed',   name:'TRAVA', icon:'🍃',col:'#27ae60',glo:'#44cc77',dur:12000,msg:'ahh... polako brate...',hard:false},
  {id:'ketamine',name:'KETAMIN',icon:'💊',col:'#0097a7',glo:'#00e5ff',dur:8000,msg:'K-HOLE... ko si ti?', hard:true},
];

let AC;
function ga(){if(!AC)AC=new(window.AudioContext||window.webkitAudioContext)();return AC;}
function snd(f,d,v=0.2,t='sine'){try{const a=ga(),o=a.createOscillator(),g=a.createGain();o.type=t;o.frequency.setValueAtTime(f,a.currentTime);g.gain.setValueAtTime(v,a.currentTime);g.gain.exponentialRampToValueAtTime(0.001,a.currentTime+d);o.connect(g);g.connect(a.destination);o.start();o.stop(a.currentTime+d);}catch(e){}}

const LANES=[-210,0,210];
let HI=0,G;

function mkWagon(wz){
  const h=Math.floor(Math.random()*40);
  return{wz,col:`hsl(${5+h},${18+Math.random()*16}%,${13+Math.random()*13}%)`,colTop:`hsl(${5+h},${14+Math.random()*12}%,${24+Math.random()*8}%)`,
    num:String(3200+Math.floor(Math.random()*6800)),
    rust:Array.from({length:8},()=>({x:Math.random(),y:0.08+Math.random()*0.82,r:0.018+Math.random()*0.055,a:Math.random()*Math.PI})),
    grn:Math.random()>0.52,grfHue:120+Math.floor(Math.random()*60),logoCol:Math.random()>0.5?'#cc4400':'#224488'};
}

function initGame(){
  const wags=[];for(let i=0;i<10;i++)wags.push(mkWagon(0.02+i*(W_LN+W_GAP)));
  G={ph:'menu',t:0,fr:0,score:0,spd:0.008,hue:0,shk:0,msg:'',msgT:0,
     streak:0,ovT:0,wasOD:false,lastHard:'',
     p:{lane:1,wx:0,jy:0,jv:0,gnd:true,eff:null,effEnd:0,mj:1,ji:0},
     obs:[],pkp:[],parts:[],wags,obT:2400,pkT:2500};
}

const KS={};
addEventListener('keydown',e=>{
  if(KS[e.code])return;KS[e.code]=true;
  if(G.ph==='overdose')return;
  if(G.ph!=='play'){initGame();G.ph='play';return;}
  if(e.code==='ArrowLeft'||e.code==='KeyA'){mvLane(-1);e.preventDefault();}
  if(e.code==='ArrowRight'||e.code==='KeyD'){mvLane(1);e.preventDefault();}
  if(['Space','ArrowUp','KeyW'].includes(e.code)){doJump();e.preventDefault();}
});
addEventListener('keyup',e=>KS[e.code]=false);
CV.addEventListener('pointerdown',e=>{
  if(G.ph==='overdose')return;
  if(G.ph!=='play'){initGame();G.ph='play';return;}
  const r=CV.getBoundingClientRect(),mx=r.left+r.width/2;
  if(e.clientX<mx-100)mvLane(-1);else if(e.clientX>mx+100)mvLane(1);else doJump();
});
function mvLane(d){const nl=Math.max(0,Math.min(2,G.p.lane+d));if(nl!==G.p.lane){G.p.lane=nl;snd(300+d*70,0.08,0.12);}}
function doJump(){const p=G.p;if(p.ji>=p.mj)return;const isH=p.eff==='heroin'||p.eff==='ketamine';p.jv=isH?5:p.eff==='cocaine'?10:8;p.gnd=false;p.ji++;snd(280,0.12,0.18);}
function burst(x,y,col,n=12,f=5){for(let i=0;i<n;i++){const a=Math.random()*Math.PI*2,sp=(0.5+Math.random())*f;G.parts.push({x,y,vx:Math.cos(a)*sp,vy:Math.sin(a)*sp-2,r:2+Math.random()*3,col,l:1,d:0.04+Math.random()*0.04});}}

function update(dt){
  const p=G.p;G.t+=dt;G.fr++;G.score+=dt/60;
  if(G.score>HI)HI=G.score;
  G.spd=0.008+G.score*0.000055;
  const isH=p.eff==='heroin'||p.eff==='ketamine';
  let sp=G.spd;
  if(isH)sp*=0.5;if(p.eff==='speed'||p.eff==='cocaine')sp*=1.55;if(p.eff==='weed')sp*=0.72;
  if(p.eff&&Date.now()>p.effEnd){p.eff=null;p.mj=1;}
  if(p.eff==='acid')G.hue=(G.hue+3)%360;
  if(G.shk>0)G.shk=Math.max(0,G.shk-dt*0.025);if(G.msgT>0)G.msgT-=dt;
  p.wx+=(LANES[p.lane]-p.wx)*0.13;
  const gv=isH?0.2:0.38;p.jv-=gv;p.jy+=p.jv;
  if(p.jy<=0){p.jy=0;p.jv=0;p.gnd=true;p.ji=0;}
  const dz=sp*dt/16.67;
  G.obs.forEach(o=>o.wz-=dz);G.pkp.forEach(q=>q.wz-=dz);G.wags.forEach(w=>w.wz-=dz);
  for(const pt of G.parts){pt.x+=pt.vx;pt.y+=pt.vy;pt.vy+=0.15;pt.l-=pt.d;}
  G.obs=G.obs.filter(o=>o.wz>-0.06);G.pkp=G.pkp.filter(q=>q.wz>-0.06&&!q.done);
  G.parts=G.parts.filter(pt=>pt.l>0);G.wags=G.wags.filter(w=>w.wz+W_LN>-0.08);
  const last=G.wags[G.wags.length-1];
  if(!last||last.wz+W_LN<0.95)G.wags.push(mkWagon(last?last.wz+W_LN+W_GAP:0.5));
  G.obT-=dt;if(G.obT<=0){G.obs.push({lane:Math.floor(Math.random()*3),wz:1.0,tall:Math.random()>0.45});G.obT=2400+Math.random()*2800;}
  G.pkT-=dt;if(G.pkT<=0){G.pkp.push({lane:Math.floor(Math.random()*3),wz:1.0,drug:DRUGS[Math.floor(Math.random()*DRUGS.length)],done:false});G.pkT=3500+Math.random()*4000;}
  for(const o of G.obs){if(o.wz>0.14||o.wz<-0.01)continue;if(o.lane!==p.lane)continue;if(p.jy<(o.tall?65:30)*0.5){die();return;}}
  for(const q of G.pkp){
    if(q.done||q.wz>0.14||q.wz<-0.01)continue;if(q.lane!==p.lane)continue;
    q.done=true;const d=q.drug;p.eff=d.id;p.effEnd=Date.now()+d.dur;
    if(d.id==='cocaine')p.mj=2;
    if(d.hard){
      G.streak++;G.lastHard=d.name+' '+d.icon;
      if(G.streak>=3){setTimeout(triggerOD,300);return;}
      G.msg=G.streak===2?`⚠ PAŽNJA — još jedna ${d.icon} = OVERDOZA!`:`${d.icon}  ${d.name}  —  ${d.msg}`;
    } else {G.streak=0;G.msg=`${d.icon}  ${d.name}  —  ${d.msg}`;}
    G.msgT=3200;G.shk=10;
    const pp=prj(LANES[p.lane],0.1);burst(pp.x,NY-40,d.glo,20,6);
    ({heroin:()=>snd(80,0.9,0.3),acid:()=>{snd(440,0.3,0.2);snd(554,0.45,0.15);},
      cocaine:()=>{snd(900,0.08,0.4,'square');snd(1300,0.12,0.25);},
      speed:()=>snd(650,0.18,0.32,'sawtooth'),weed:()=>snd(180,1.2,0.22),
      ketamine:()=>{snd(110,1.4,0.28);snd(82,2.0,0.18);}}[d.id])?.();
  }
}
function die(){G.ph='dead';if(G.score>HI)HI=G.score;snd(220,0.7,0.3,'sawtooth');}

function triggerOD(){
  if(G.ph!=='play')return;
  G.ph='overdose';G.ovT=0;G.wasOD=true;if(G.score>HI)HI=G.score;
  snd(58,0.35,0.4);setTimeout(()=>snd(52,0.45,0.34),550);
  setTimeout(()=>snd(44,0.7,0.26),1200);setTimeout(()=>snd(36,1.4,0.16),2100);
  setTimeout(()=>snd(820,4.5,0.055),3400);
}

function rr(x,y,w,h,r){cx.beginPath();cx.moveTo(x+r,y);cx.lineTo(x+w-r,y);cx.arcTo(x+w,y,x+w,y+r,r);cx.lineTo(x+w,y+h-r);cx.arcTo(x+w,y+h,x+w-r,y+h,r);cx.lineTo(x+r,y+h);cx.arcTo(x,y+h,x,y+h-r,r);cx.lineTo(x,y+r);cx.arcTo(x,y,x+r,y,r);cx.closePath();}

let BG=null;
function getBG(){
  if(BG)return BG;BG=document.createElement('canvas');BG.width=W;BG.height=H;
  const bx=BG.getContext('2d');
  const sg=bx.createLinearGradient(0,0,0,VY);sg.addColorStop(0,'#030310');sg.addColorStop(1,'#080820');
  bx.fillStyle=sg;bx.fillRect(0,0,W,VY);
  bx.fillStyle='rgba(255,255,255,0.8)';for(let i=0;i<110;i++)bx.fillRect(Math.random()*W,Math.random()*VY,Math.random()<0.1?2:1,1);
  bx.fillStyle='#ccc870';bx.beginPath();bx.arc(700,40,18,0,Math.PI*2);bx.fill();
  bx.fillStyle='#030310';bx.beginPath();bx.arc(708,35,14,0,Math.PI*2);bx.fill();
  const bl=[[0,52],[62,82],[128,60],[195,98],[258,66],[318,86],[378,50],[445,72],[500,56],[558,90],[618,68],[672,54],[728,80],[778,60],[800,70]];
  bx.fillStyle='#07071a';bx.beginPath();bx.moveTo(0,VY);
  for(let i=0;i<bl.length-1;i++){bx.lineTo(bl[i][0],VY-bl[i][1]);bx.lineTo(bl[i+1][0]-1,VY-bl[i][1]);}
  bx.lineTo(W,VY);bx.closePath();bx.fill();
  bx.fillStyle='rgba(255,200,50,0.1)';for(let i=0;i<55;i++)bx.fillRect(Math.random()*W,Math.random()*VY*0.88,3,4);
  return BG;
}

function drawWagonFace(w){
  const wz0=w.wz,wz1=w.wz+W_LN;
  if(wz1<=0.015||wz0>=1.0)return;
  const wza=Math.max(0.02,wz0),wzb=Math.min(0.98,wz1);
  const pA=prj(W_WX,wza),pB=prj(W_WX,wzb);
  const hA=W_HT*pA.s,hB=W_HT*pB.s;
  const xA=pA.x,yBA=pA.y,yTA=pA.y-hA,xB=pB.x,yBB=pB.y,yTB=pB.y-hB;
  if(xA>W/2-30)return;
  const alpha=Math.min(1,(wza-0.015)/0.04)*Math.min(1,(0.98-wzb)/0.04);
  if(alpha<=0.01)return;
  cx.globalAlpha=alpha;
  function wp(th,tv){const x=xA+(xB-xA)*th,yT=yTA+(yTB-yTA)*th,yB=yBA+(yBB-yBA)*th;return{x,y:yT+(yB-yT)*tv};}
  function quad(c0,c1,c2,c3,sty){cx.beginPath();cx.moveTo(c0.x,c0.y);cx.lineTo(c1.x,c1.y);cx.lineTo(c2.x,c2.y);cx.lineTo(c3.x,c3.y);cx.closePath();cx.fillStyle=sty;cx.fill();}
  function ql(p1,p2,sty,lw){cx.strokeStyle=sty;cx.lineWidth=lw;cx.beginPath();cx.moveTo(p1.x,p1.y);cx.lineTo(p2.x,p2.y);cx.stroke();}
  const sc=pA.s,tl=wp(0,0),tr=wp(1,0),br=wp(1,1),bl=wp(0,1);
  quad(tl,tr,br,bl,w.col);
  const vg=cx.createLinearGradient(xA,yTA,xA,yBA);
  vg.addColorStop(0,'rgba(255,255,255,0.15)');vg.addColorStop(0.18,'rgba(255,255,255,0.04)');vg.addColorStop(0.72,'rgba(0,0,0,0.06)');vg.addColorStop(1,'rgba(0,0,0,0.55)');
  quad(tl,tr,br,bl,vg);
  if(sc>0.38){const ledgeH=10*sc,lt2={x:tl.x,y:tl.y-ledgeH},rt2={x:tr.x,y:tr.y-ledgeH*0.6};quad(lt2,rt2,tr,tl,w.colTop);ql(lt2,rt2,'rgba(0,0,0,0.5)',Math.max(0.5,1.5*sc));ql(lt2,rt2,'rgba(255,255,255,0.18)',Math.max(0.3,0.7*sc));}
  quad(tl,tr,wp(1,0.04),wp(0,0.04),'rgba(255,255,255,0.14)');
  [0.34,0.67].forEach(tv=>{quad(wp(0,tv-0.022),wp(1,tv-0.022),wp(1,tv+0.022),wp(0,tv+0.022),'rgba(0,0,0,0.38)');quad(wp(0,tv+0.022),wp(1,tv+0.022),wp(1,tv+0.06),wp(0,tv+0.06),'rgba(0,0,0,0.18)');ql(wp(0,tv-0.026),wp(1,tv-0.026),'rgba(255,255,255,0.12)',Math.max(0.5,1.2*sc));});
  for(let i=1;i<4;i++){const th=i/4;ql(wp(th,0.03),wp(th,0.97),'rgba(0,0,0,0.42)',Math.max(0.5,1.8*sc));ql({x:wp(th,0.03).x+1.2,y:wp(th,0.03).y},{x:wp(th,0.97).x+1.2,y:wp(th,0.97).y},'rgba(255,255,255,0.07)',Math.max(0.3,0.8*sc));}
  if(sc>0.28){const dopa=Math.min(1,(sc-0.28)/0.18),dl=0.375,dr=0.625,dt=0.09,db=0.91;quad(wp(dl,dt),wp(dr,dt),wp(dr,db),wp(dl,db),`rgba(0,0,0,${0.22*dopa})`);cx.strokeStyle=`rgba(0,0,0,${0.55*dopa})`;cx.lineWidth=Math.max(1,2.5*sc);cx.beginPath();cx.moveTo(wp(dl,dt).x,wp(dl,dt).y);cx.lineTo(wp(dr,dt).x,wp(dr,dt).y);cx.lineTo(wp(dr,db).x,wp(dr,db).y);cx.lineTo(wp(dl,db).x,wp(dl,db).y);cx.closePath();cx.stroke();ql(wp(0.5,dt+0.01),wp(0.5,db-0.01),`rgba(0,0,0,${0.4*dopa})`,Math.max(0.5,sc));if(sc>0.5){const h1=wp(0.52,0.5),h2=wp(0.52,0.56);cx.strokeStyle=`rgba(160,140,110,${0.65*dopa})`;cx.lineWidth=Math.max(2,3.5*sc);cx.beginPath();cx.moveTo(h1.x,h1.y);cx.lineTo(h2.x,h2.y);cx.stroke();cx.fillStyle=`rgba(180,160,120,${0.7*dopa})`;cx.beginPath();cx.arc(h1.x,h1.y,2.5*sc,0,Math.PI*2);cx.fill();}}
  if(sc>0.45){const rs=Math.max(1.5,4*sc),opa=Math.min(1,(sc-0.45)/0.2);[[0,0],[1,0],[0,0.34],[1,0.34],[0,0.67],[1,0.67],[0,1],[1,1],[0.25,0],[0.5,0],[0.75,0],[0.25,1],[0.5,1],[0.75,1]].forEach(([th,tv])=>{const pt=wp(th,tv);cx.fillStyle=`rgba(150,130,100,${0.7*opa})`;cx.beginPath();cx.arc(pt.x,pt.y,rs,0,Math.PI*2);cx.fill();cx.fillStyle=`rgba(255,255,255,${0.35*opa})`;cx.beginPath();cx.arc(pt.x-rs*0.35,pt.y-rs*0.35,rs*0.42,0,Math.PI*2);cx.fill();cx.fillStyle=`rgba(0,0,0,${0.3*opa})`;cx.beginPath();cx.arc(pt.x+rs*0.2,pt.y+rs*0.2,rs*0.35,0,Math.PI*2);cx.fill();});}
  if(sc>0.25){const na=Math.min(1,(sc-0.25)/0.22),mp=wp(0.5,0.5),fs=Math.max(10,44*sc);cx.font=`bold ${fs}px monospace`;cx.textAlign='center';cx.fillStyle=`rgba(220,208,185,${0.11*na})`;cx.fillText(w.num,mp.x,mp.y+fs*0.38);if(sc>0.4){const la=Math.min(1,(sc-0.4)/0.2),lp=wp(0.5,0.18);cx.fillStyle=`rgba(${w.logoCol.replace('#','').match(/../g).map(x=>parseInt(x,16)).join(',')},${0.25*la*na})`;const lw2=Math.max(15,65*sc),lh2=Math.max(4,10*sc);cx.fillRect(lp.x-lw2/2,lp.y-lh2/2,lw2,lh2);}cx.textAlign='left';}
  w.rust.forEach(rs=>{if(sc<0.16)return;const rp=wp(rs.x,rs.y),r2=rs.r*42*sc;if(r2<1.8)return;cx.fillStyle=`rgba(108,40,12,${0.25+rs.r*1.6})`;cx.beginPath();cx.ellipse(rp.x,rp.y,r2,r2*0.5,rs.a,0,Math.PI*2);cx.fill();cx.fillStyle=`rgba(158,62,18,${0.14+rs.r*0.65})`;cx.beginPath();cx.ellipse(rp.x-r2*0.22,rp.y-r2*0.18,r2*0.52,r2*0.3,rs.a+0.4,0,Math.PI*2);cx.fill();if(r2>5){cx.strokeStyle=`rgba(140,55,15,${0.15+rs.r*0.5})`;cx.lineWidth=Math.max(1,r2*0.18);cx.beginPath();cx.moveTo(rp.x,rp.y+r2*0.4);cx.lineTo(rp.x+r2*0.15,rp.y+r2*1.6);cx.stroke();}});
  if(w.grn&&sc>0.2){const ga=Math.min(0.72,sc*0.9)*Math.min(1,(sc-0.2)/0.14);quad(wp(0.04,0.56),wp(0.96,0.56),wp(0.96,0.76),wp(0.04,0.76),`hsla(${w.grfHue},55%,32%,${ga})`);quad(wp(0.05,0.61),wp(0.95,0.61),wp(0.95,0.66),wp(0.05,0.66),`hsla(${(w.grfHue+30)%360},70%,55%,${ga*0.6})`);}
  quad(wp(0,0.88),wp(1,0.88),br,bl,'rgba(0,0,0,0.45)');
  cx.strokeStyle=`rgba(0,0,0,${0.65+sc*0.3})`;cx.lineWidth=Math.max(1,2.2*sc);cx.beginPath();cx.moveTo(tl.x,tl.y);cx.lineTo(tr.x,tr.y);cx.lineTo(br.x,br.y);cx.lineTo(bl.x,bl.y);cx.closePath();cx.stroke();
  if(sc>0.55){for(let i=0;i<3;i++){const t=(i+0.5)/3,wpt=wp(t,1.0),wr=Math.max(5,14*sc*(1-t*0.22)),wy=wpt.y+wr*0.28;if(i===0||i===2){cx.fillStyle=`rgba(20,20,20,${0.8*sc})`;cx.fillRect(wpt.x-wr*1.8,wpt.y-2,wr*3.6,6);}cx.fillStyle='#0c0c0c';cx.beginPath();cx.arc(wpt.x,wy,wr,0,Math.PI*2);cx.fill();cx.strokeStyle='#1a1a1a';cx.lineWidth=wr*0.3;cx.beginPath();cx.arc(wpt.x,wy,wr*0.82,0,Math.PI*2);cx.stroke();cx.fillStyle='#252525';cx.beginPath();cx.arc(wpt.x,wy,wr*0.55,0,Math.PI*2);cx.fill();cx.strokeStyle='#1e1e1e';cx.lineWidth=Math.max(1,wr*0.12);for(let s=0;s<6;s++){const sa=s*Math.PI/3;cx.beginPath();cx.moveTo(wpt.x+Math.cos(sa)*wr*0.2,wy+Math.sin(sa)*wr*0.2);cx.lineTo(wpt.x+Math.cos(sa)*wr*0.72,wy+Math.sin(sa)*wr*0.72);cx.stroke();}cx.fillStyle='#3a3a3a';cx.beginPath();cx.arc(wpt.x,wy,wr*0.18,0,Math.PI*2);cx.fill();}cx.strokeStyle=`rgba(18,18,18,${0.7*sc})`;cx.lineWidth=Math.max(2,4*sc);cx.beginPath();cx.moveTo(wp(0.02,1).x,wp(0.02,1).y+3);cx.lineTo(wp(0.98,1).x,wp(0.98,1).y+3);cx.stroke();}
  const sg=cx.createLinearGradient(xA,0,xA+62,0);sg.addColorStop(0,`rgba(0,0,0,${0.48*sc})`);sg.addColorStop(1,'rgba(0,0,0,0)');cx.fillStyle=sg;cx.fillRect(xA,yBA-4,62,NY-yBA+12);
  cx.globalAlpha=1;
}

function drawScene(){
  cx.drawImage(getBG(),0,0);
  const gg=cx.createLinearGradient(0,VY,0,H);gg.addColorStop(0,'#14100a');gg.addColorStop(1,'#1e1408');
  cx.fillStyle=gg;cx.fillRect(0,VY,W,H-VY);
  {const rf=prj(245,1),rn=prj(245,0),rf2=prj(500,1),rn2=prj(500,0);
  const rdg=cx.createLinearGradient(0,VY,0,NY);rdg.addColorStop(0,'#181818');rdg.addColorStop(1,'#232323');
  cx.fillStyle=rdg;cx.beginPath();cx.moveTo(rf.x,rf.y);cx.lineTo(rf2.x,rf2.y);cx.lineTo(rn2.x,NY+14);cx.lineTo(rn.x,NY+14);cx.closePath();cx.fill();
