  cx.fillStyle='#777';cx.font='11px Courier New';cx.fillText('Edukativna igrica o uticaju droga na organizam',W/2,H*0.31);
  cx.fillStyle='#888';cx.font='13px Courier New';cx.fillText('Preskoči prepreke  ·  Skupi drogu  ·  Beži od džipa',W/2,H*0.39);
  cx.font='26px serif';cx.fillText(DRUGS.map(d=>d.icon).join('   '),W/2,H*0.51);
  cx.fillStyle='#555';cx.font='10px Courier New';
  cx.fillText('💉 heroin  ·  🔮 acid  ·  ❄️ kokain  ·  ⚡ speed  ·  🍃 trava  ·  💊 ketamin',W/2,H*0.61);
  cx.fillStyle='#883333';cx.font='11px Courier New';cx.fillText('⚠  3× heroin ili ketamin zaredom = OVERDOZA',W/2,H*0.69);
  if(Math.floor(G.t/700)%2===0){cx.fillStyle='#cc44ff';cx.font='bold 17px Courier New';cx.fillText('▶  SPACE / KLIK za START',W/2,H*0.81);}
  cx.textAlign='left';
}

function drawDead(){
  cx.fillStyle='rgba(0,0,0,0.85)';cx.fillRect(0,0,W,H);cx.textAlign='center';
  if(G.wasOD){
    cx.fillStyle='#ff4444';cx.font='bold 36px Courier New';cx.shadowColor='#ff0000';cx.shadowBlur=20;cx.fillText('PREDOZIRANJE',W/2,H*0.18);cx.shadowBlur=0;
    cx.fillStyle='#ffaaaa';cx.font='12px Courier New';cx.fillText('Heroin i Ketamin su depresanti centralnog nervnog sistema.',W/2,H*0.28);
    cx.fillText('Kombinuju se sa prirodnim opioidnim receptorima i zaustavljaju disanje.',W/2,H*0.34);
    cx.fillStyle='#ffff88';cx.font='bold 13px Courier New';cx.fillText('📞  Hitna pomoć: 112  |  Centar za prevenciju: 011/3444-000',W/2,H*0.43);
    cx.fillStyle='#aaffcc';cx.font='12px Courier New';cx.fillText('💊  Nalokson blokira opijate — dostupan u apotekama bez recepta.',W/2,H*0.51);
    cx.fillStyle='#aaccff';cx.fillText('Ako poznaješ nekoga sa problemom zavisnosti — traži stručnu pomoć.',W/2,H*0.58);
    cx.fillStyle='#f1c40f';cx.font='14px Courier New';cx.fillText(`Rekord: ${Math.floor(HI)}`,W/2,H*0.68);
  } else {
    cx.fillStyle='#e74c3c';cx.font='bold 54px Courier New';cx.shadowColor='#ff0000';cx.shadowBlur=28;cx.fillText('UHVAĆEN!',W/2,H*0.35);cx.shadowBlur=0;
    cx.fillStyle='#bbb';cx.font='18px Courier New';cx.fillText(`Bodovi: ${Math.floor(G.score)}`,W/2,H*0.5);
    cx.fillStyle='#f1c40f';cx.fillText(`Rekord: ${Math.floor(HI)}`,W/2,H*0.61);
  }
  if(Math.floor(G.t/600)%2===0){cx.fillStyle='#666';cx.font='13px Courier New';cx.fillText('[ SPACE / KLIK — novi pokušaj ]',W/2,H*0.82);}
  cx.textAlign='left';
}

function render(){
  cx.clearRect(0,0,W,H);cx.save();
  if(G.shk>0)cx.translate((Math.random()-0.5)*G.shk*2,(Math.random()-0.5)*G.shk);
  if(G.p.eff==='acid')cx.filter=`hue-rotate(${G.hue}deg) saturate(2.5) brightness(1.06)`;
  drawScene();drawSUV();
  [...G.obs.map(o=>({...o,_:'o'})),...G.pkp.filter(q=>!q.done).map(q=>({...q,_:'p'}))]
    .sort((a,b)=>b.wz-a.wz).forEach(obj=>obj._==='o'?drawObs(obj):drawPickup(obj));
  drawPlayer();drawFX();
  for(const pt of G.parts){cx.globalAlpha=Math.max(0,pt.l);cx.fillStyle=pt.col;cx.beginPath();cx.arc(pt.x,pt.y,pt.r,0,Math.PI*2);cx.fill();}
  cx.globalAlpha=1;cx.filter='none';cx.restore();
  drawHUD();
  if(G.ph==='overdose')drawOverdose();
  if(G.ph==='menu')drawMenu();
  if(G.ph==='dead')drawDead();
}

let prevT=0;
function loop(ts){
  requestAnimationFrame(loop);const dt=Math.min(ts-prevT,50);prevT=ts;
  if(G.ph==='play')update(dt);
  else if(G.ph==='overdose'){G.ovT+=dt;G.t+=dt;if(G.ovT>6000)G.ph='dead';}
  else G.t+=dt;
  render();
}
initGame();requestAnimationFrame(loop);
</script></body></html>
