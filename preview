function drawOverdose(){
  const t=G.ovT,prog=Math.min(1,t/5600);
  // Srčani ritam — ubrzava pa staje
  const hbP=Math.max(250,700-prog*600),hbFase=(t%hbP)/hbP;
  const beat=prog<0.65?Math.pow(Math.max(0,Math.sin(hbFase*Math.PI*2)),18)*0.48:0;
  // Crveni vinjeting
  const vr=cx.createRadialGradient(W/2,H/2,H*(0.3-prog*0.26),W/2,H/2,H*0.92);
  vr.addColorStop(0,'rgba(0,0,0,0)');vr.addColorStop(1,`rgba(110,0,0,${0.3+prog*0.65+beat*0.28})`);
  cx.fillStyle=vr;cx.fillRect(0,0,W,H);
  if(beat>0.08){cx.fillStyle=`rgba(255,255,255,${beat*0.2})`;cx.fillRect(0,0,W,H);}

  // EKG linija
  if(t>350&&t<4000){
    cx.save();cx.globalAlpha=Math.min(1,(t-350)/300)*0.88;cx.strokeStyle='#22dd44';cx.lineWidth=2;
    const lx=55,ly=H*0.77,lw=W-110;cx.beginPath();cx.moveTo(lx,ly);
    const nb=Math.min(5,Math.floor((t-350)/620));let cx2=lx;
    for(let i=0;i<nb;i++){const seg=lw/6;cx.lineTo(cx2+seg*0.24,ly);cx.lineTo(cx2+seg*0.31,ly-38);cx.lineTo(cx2+seg*0.38,ly+22);cx.lineTo(cx2+seg*0.44,ly);cx2+=seg;}
    if(t>2900){cx.lineTo(lx+lw,ly);cx.strokeStyle='#22dd44';}else cx.lineTo(cx2,ly);
    cx.stroke();
    if(t>2900){cx.fillStyle='#22dd44';cx.font='10px Courier New';cx.textAlign='right';cx.fillText('FLATLINE ──────',W-58,H*0.77-10);cx.textAlign='left';}
    cx.restore();
  }

  // Naslov OVERDOZA
  if(t>500){
    const ta=Math.min(1,(t-500)/550);cx.globalAlpha=ta;cx.textAlign='center';
    cx.shadowColor='#ff0000';cx.shadowBlur=55;cx.fillStyle='#fff';
    cx.font=`bold ${Math.min(68,38+prog*32)}px Courier New`;
    cx.fillText('OVERDOZA',W/2,H*0.22);cx.shadowBlur=0;cx.globalAlpha=1;
  }
  // Uzrok
  if(t>950&&G.lastHard){
    cx.globalAlpha=Math.min(1,(t-950)/420);cx.textAlign='center';
    cx.fillStyle='#ff9999';cx.font='14px Courier New';
    cx.fillText(`${G.lastHard} × 3 zaredom — predoziranje depresantima CNS-a`,W/2,H*0.32);cx.globalAlpha=1;
  }

  // Edukativne informacije — pojavljuju se jedna po jedna
  const info=[
    {at:1400,txt:'⚠  HEROIN i KETAMIN usporavaju disanje i zaustavljaju srce',   c:'#ffaaaa'},
    {at:2000,txt:'Predoziranje zaustavlja disanje — smrt nastupa za nekoliko minuta', c:'#ffcc99'},
    {at:2600,txt:'📞  ODMAH ZOVI 112 — ne čekaj, svaka sekunda je važna',         c:'#ffff88'},
    {at:3200,txt:'💊  Nalokson (Narcan) poništava efekte opijata i spašava živote', c:'#aaffcc'},
    {at:3900,txt:'Postavi osobu u bočni položaj — sprečava gušenje',              c:'#aaccff'},
  ];
  info.forEach((inf,i)=>{
    if(t<inf.at)return;
    const ia=Math.min(1,(t-inf.at)/450)*(prog<0.94?1:0);
    cx.globalAlpha=ia*0.92;
    const iy=H*0.42+i*32;cx.fillStyle='rgba(0,0,0,0.58)';cx.fillRect(W*0.04,iy-16,W*0.92,24);
    cx.fillStyle=inf.c;cx.font='12px Courier New';cx.textAlign='center';cx.fillText(inf.txt,W/2,iy);
    cx.globalAlpha=1;
  });

  if(prog>0.9){cx.fillStyle=`rgba(0,0,0,${(prog-0.9)/0.1})`;cx.fillRect(0,0,W,H);}
  cx.textAlign='left';
}

